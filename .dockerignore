# -----------------------------------------------------------------------------
# Version Control
# -----------------------------------------------------------------------------
.git
.gitignore
.gitattributes

# -----------------------------------------------------------------------------
# Python Environments & Caches
# -----------------------------------------------------------------------------
.venv
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# -----------------------------------------------------------------------------
# Environment / Secrets
# -----------------------------------------------------------------------------
# Never bake secrets into the image — inject them at runtime via
# environment variables or Railway/Docker secrets instead.
.env
.env.*
jwt_secret.py

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp

# -----------------------------------------------------------------------------
# Docker-related
# -----------------------------------------------------------------------------
Dockerfile
docker-compose.yml
.dockerignore

# -----------------------------------------------------------------------------
# Frontend (backend image doesn't need it)
# -----------------------------------------------------------------------------
frontend/

# -----------------------------------------------------------------------------
# Tests, Docs, Logs
# -----------------------------------------------------------------------------
backend/tests/
*.log
logs/

